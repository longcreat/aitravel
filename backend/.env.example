OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2
CORS_ALLOW_ORIGINS=http://localhost:5173
CHAT_SQLITE_PATH=
JWT_SECRET=
JWT_EXPIRE_DAYS=7
AUTH_CODE_EXPIRE_MINUTES=10
SMTP_HOST=
# 常见 587 = STARTTLS
# 常见 465 = SSL
# 网易企业邮箱常见 994 = SSL
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Optional MCP env vars (only needed if backend/config/mcp.servers.json uses them)
TRAVEL_MCP_URL=
TRAVEL_MCP_TOKEN=
CALENDAR_API_KEY=
