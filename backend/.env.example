# OpenAI-compatible 连接配置；也可用于阿里百炼兼容接口
OPENAI_API_KEY=your-dashscope-api-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_MODEL_PROVIDER=qwen
LLM_TEMPERATURE=0.2
# 会话级模型档位（普通 / 思考）
LLM_PROFILE_DEFAULT=standard
LLM_PROFILE_STANDARD_LABEL=普通
LLM_PROFILE_STANDARD_MODEL=qwen-plus
LLM_PROFILE_STANDARD_PROVIDER=qwen
LLM_PROFILE_STANDARD_TEMPERATURE=0.2
LLM_PROFILE_THINKING_LABEL=思考
LLM_PROFILE_THINKING_MODEL=qwen-max
LLM_PROFILE_THINKING_PROVIDER=qwen
LLM_PROFILE_THINKING_TEMPERATURE=0.2
CORS_ALLOW_ORIGINS=http://localhost:5173
CHAT_SQLITE_PATH=
# 开发环境可显式开启：启动时先删除 chat.db 再按最新 migration 重建
DEV_RESET_CHAT_DB=false
# 必填：用于签发和校验登录 JWT，请替换成随机长字符串
JWT_SECRET=
JWT_EXPIRE_DAYS=7
AUTH_CODE_EXPIRE_MINUTES=10
SMTP_HOST=
# 常见 587 = STARTTLS
# 常见 465 = SSL
# 网易企业邮箱常见 994 = SSL
SMTP_PORT=587
SMTP_USERNAME=
# 密码里包含 `$` 时直接原样填写即可，例如 abc$def。
# 后端会关闭 dotenv 变量插值解析，避免把 `$def` 当成环境变量。
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Optional MCP env vars (only needed if backend/config/mcp.servers.json uses them)
TRAVEL_MCP_URL=
TRAVEL_MCP_TOKEN=
CALENDAR_API_KEY=

# Optional local API tool env vars
EXA_API_KEY=

# Optional LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-travel-agent-dev
# LANGSMITH_WORKSPACE_ID=

# Optional streaming TTS (CosyVoice + R2)
ALIYUN_TTS_API_KEY=
ALIYUN_TTS_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference
ALIYUN_TTS_MODEL=cosyvoice-v3-flash
ALIYUN_TTS_VOICE=longanyang
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
